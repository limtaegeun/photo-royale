rules_version = '2';

// Firestore 보안 규칙의 단일 진실원. 변경 후 `firebase deploy --only firestore:rules`로
// 배포한다(firebase.json에 연결됨). 콘솔에서 직접 수정하면 이 파일과 어긋나므로 금지.
service cloud.firestore {
  match /databases/{database}/documents {
    // 신규 users 문서 스키마 검증 — 필드 화이트리스트 + 타입/값/길이 제약.
    // 정상 클라이언트(useSignup)와 같은 규칙(닉네임 2~12자, 한글·영문·숫자)을 서버에서도
    // 강제해, SDK 직접 호출로 예약 키와 다른 표시 닉네임·임의 필드·비정상 gender를
    // 쓰는 것을 막는다. 한계: rules는 NFC 정규화를 못 하므로 유니코드 정규화 자체는
    // 클라이언트(toNicknameKey) 책임으로 남는다.
    function isValidNewUser(data) {
      return data.keys().hasAll(['email', 'nickname', 'nicknameKey', 'gender', 'createdAt'])
        && data.keys().hasOnly(['email', 'nickname', 'nicknameKey', 'gender', 'createdAt'])
        && data.email is string
        && data.email.size() >= 3
        && data.email.size() <= 320
        && data.nickname is string
        && data.nickname.size() >= 2
        && data.nickname.size() <= 12
        && data.nickname.matches('^[가-힣ㄱ-ㅎㅏ-ㅣA-Za-z0-9]+$')
        && data.nicknameKey == data.nickname.lower()
        && data.gender in ['male', 'female']
        && data.createdAt == request.time; // serverTimestamp()는 rules에서 request.time과 같다
    }

    // 닉네임 유니크 인덱스. 문서 ID = 정규화 키(trim → NFC → lowercase,
    // src/features/auth/api/signup.ts toNicknameKey와 동일 규칙), 내용은 소유자 uid뿐.
    match /nicknames/{nickname} {
      // 가입 폼의 미인증 가용성 검사는 단건 get만 허용하고,
      // list를 막아 닉네임 전체 수집을 방지한다.
      allow get: if true;
      allow list: if false;

      // 존재하지 않는 키에만 create가 성립하므로 유니크가 서버에서 강제된다.
      // 같은 트랜잭션에서 users/{uid}가 이 키를 nicknameKey로 참조해야 한다(getAfter).
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.nicknameKey == nickname;

      // 닉네임 변경/탈퇴 플로우 도입 전까지 예약은 불변이다.
      allow update, delete: if false;
    }

    match /users/{uid} {
      // 프로필(이메일 포함)은 본인만 읽는다. 닉네임 가용성 검사는 nicknames 컬렉션이
      // 담당하므로 users를 공개로 열 이유가 없다.
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list: if false;

      // 본인 문서이면서 스키마 검증(isValidNewUser)을 통과하고, 같은 트랜잭션에
      // 닉네임 예약이 함께 있어야 생성된다(상호 참조).
      allow create: if request.auth != null
        && request.auth.uid == uid
        && isValidNewUser(request.resource.data)
        && getAfter(/databases/$(database)/documents/nicknames/$(request.resource.data.nicknameKey)).data.uid == uid;

      // 프로필 수정 플로우 도입 시 닉네임 재예약 규칙과 함께 재설계한다.
      allow update, delete: if false;
    }

    // 대기실. 문서 ID = 초대 코드(waiting-room/api/rooms.ts generateRoomCode와 동일 형식 —
    // 혼동 문자 0/O·1/I/L 제외 4자).
    match /rooms/{roomCode} {
      // 초대 코드를 아는 로그인 사용자만 단건 조회한다(입장 전 코드 검증·참가 트랜잭션).
      allow get: if request.auth != null;

      // list는 "내가 만든 방" 조회(where hostUid == 본인)를 만족하는 쿼리만 허용한다 —
      // 조건 없는 전체 방 코드 수집은 계속 거부된다(fetchMyRooms 참조).
      allow list: if request.auth != null
        && resource.data.hostUid == request.auth.uid;

      // 존재하지 않는 코드에만 create가 성립하므로(createRoom 트랜잭션의 존재 검사와 함께)
      // 코드 유니크가 서버에서 강제된다.
      allow create: if request.auth != null
        && roomCode.matches('^[A-HJKMNP-Z2-9]{4}$')
        && request.resource.data.keys().hasOnly(['hostUid', 'status', 'createdAt'])
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'waiting'
        && request.resource.data.createdAt == request.time;

      // 호스트 본인만. 두 갈래로 나뉜다.
      allow update: if request.auth != null
        && request.auth.uid == resource.data.hostUid
        && (
          // 1) 게임 시작 — status 필드만, waiting → playing 단방향 전이만 허용한다.
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
            && resource.data.status == 'waiting'
            && request.resource.data.status == 'playing')
          // 2) 배정 확정 — 팀편성 차수(+1)와 게임 모드를 함께 커밋한다. 아직 대기 중일 때만 허용한다.
          //    모드는 확정과 함께만 커밋된다(드래프트는 로컬) — assignmentRound +1 제약을 유지하므로
          //    모드만 단독으로 바꾸는 요청은(차수가 그대로라) 거부된다.
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignmentRound', 'gameMode'])
            && resource.data.status == 'waiting'
            && request.resource.data.assignmentRound is int
            && request.resource.data.assignmentRound ==
              (('assignmentRound' in resource.data) ? resource.data.assignmentRound + 1 : 1)
            && request.resource.data.gameMode in ['normal', 'tail-chase', 'group', 'king-hunt', 'staff-chase', 'bomb-plant', 'kkomkkomi', 'fast-survival'])
        );

      // 방 정리(삭제) 플로우 도입 전까지 불변이다.
      allow delete: if false;

      // 참가자. 문서 ID = 참가자 uid — 재입장(joinRoom)이 자연스럽게 멱등이 된다.
      match /participants/{uid} {
        // 명단은 같은 방 사람끼리 실시간 구독으로 봐야 한다. 경로 접근에 초대 코드가
        // 필요하므로 로그인 사용자 전체 허용으로 충분하다(MVP).
        allow read: if request.auth != null;

        // 본인 문서만, 대기(isReady=false) 상태로, 존재하는 방에만 생성한다.
        // 닉네임은 users 스키마와 같은 제약(2~12자, 한글·영문·숫자)을 강제한다.
        // gender는 명단 표기용 optional — 있으면 값을 검증한다(프로필 조회 실패 시 생략 허용).
        allow create: if request.auth != null
          && request.auth.uid == uid
          && exists(/databases/$(database)/documents/rooms/$(roomCode))
          && request.resource.data.keys().hasAll(['nickname', 'isReady', 'joinedAt'])
          && request.resource.data.keys().hasOnly(['nickname', 'gender', 'isReady', 'joinedAt'])
          && request.resource.data.nickname is string
          && request.resource.data.nickname.size() >= 2
          && request.resource.data.nickname.size() <= 12
          && request.resource.data.nickname.matches('^[가-힣ㄱ-ㅎㅏ-ㅣA-Za-z0-9]+$')
          && (!('gender' in request.resource.data) || request.resource.data.gender in ['male', 'female'])
          && request.resource.data.isReady == false
          && request.resource.data.joinedAt == request.time;

        // 두 갈래로 나뉜다.
        allow update: if
          // 1) 본인의 레디 확정만 허용한다(레디 해제 플로우는 아직 없다).
          (request.auth != null
            && request.auth.uid == uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isReady'])
            && request.resource.data.isReady == true)
          // 2) 호스트 배정 확정 배치 쓰기 — 드래프트는 로컬이라 확정 시에만 서버에 닿는다.
          //    team(완장)·X 겸직·이월값을 쓰고, 라운드마다 재레디를 위해 isReady를 false로 리셋한다.
          || (request.auth != null
            && get(/databases/$(database)/documents/rooms/$(roomCode)).data.hostUid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['team', 'isXTeam', 'sameGenderStreak', 'previousPartnerIds', 'isReady'])
            && request.resource.data.team is string
            && request.resource.data.team.size() == 1
            && request.resource.data.team.matches('^[A-Z]$')
            && request.resource.data.isXTeam is bool
            && request.resource.data.sameGenderStreak is int
            && request.resource.data.sameGenderStreak >= 0
            && request.resource.data.previousPartnerIds is list
            && request.resource.data.isReady == false);

        // 퇴장(문서 삭제) 처리 도입 전까지 참가 기록은 불변이다.
        allow delete: if false;
      }
    }
  }
}
